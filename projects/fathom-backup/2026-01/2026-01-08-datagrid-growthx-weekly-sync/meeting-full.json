        {
            "speaker": {
                "display_name": "Vivek Shankar",
                "matched_calendar_invitee_email": "vivek@growthxlabs.com"
            },
            "text": "So that targets AI engineers, AI agent designers, et cetera, people that Tiago had flagged as being decision makers.",

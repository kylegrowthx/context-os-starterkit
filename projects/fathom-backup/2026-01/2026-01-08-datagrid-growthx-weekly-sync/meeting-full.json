        },
        {
            "speaker": {
                "display_name": "Vivek Shankar",
                "matched_calendar_invitee_email": "vivek@growthxlabs.com"
            },
            "text": "The most popular articles over, in terms of the LLM referrals, were usually the statistics articles.",

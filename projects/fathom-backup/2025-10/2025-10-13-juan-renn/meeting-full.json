        },
        {
            "speaker": {
                "display_name": "Renato Valdes Olmos",
                "matched_calendar_invitee_email": "renato@growthx.ai"
            },
            "text": "Maar ik wil gewoon eventjes kijken of jij dat blok vrij kan maken voor ons.",
